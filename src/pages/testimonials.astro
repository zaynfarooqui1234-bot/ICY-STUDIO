---
import { Navbar } from "../components/Navbar.tsx"
import Layout from "../layouts/Layout.astro"
import { Image } from 'astro:assets';
import { Footer } from '../components/Footer.tsx'

import arrow from '../images/arrow-scroll.png';
import test1 from '../images/test1.svg';
import test2 from '../images/test2.svg';
import WorkPrivacyPolicy from "../components/WorkPrivacyPolicy.astro";
import UserReviews from '../components/UserReviews.astro';
import VideoTestimonials from '../components/VideoTestimonials.astro';
---

<Layout title="Icy Studio - Testimonials">
    <Navbar white client:load/>

    <div class=" absolute z-20 flex flex-col select-none px-[clamp(20px,4.4vw,64px)] pb-[clamp(24px,2.8vw,40px)] pt-[clamp(72px,8.9vw,128px)]">
        <button class="h-[clamp(42px,6.25vw,64px)] w-[clamp(190px,29.3vw,300px)] rounded-full bg-transparent px-[clamp(14px,1.6vw,24px)] py-1 pt-[clamp(4px,0.8vw,8px)] font-glancyrRegular text-[clamp(22px,3.5vw,36px)] text-white outline outline-1 outline-neon-green">
          TESTIMONIALS
        </button>
    </div>

    <div class="relative flex min-h-svh w-full select-none flex-col items-center justify-center overflow-hidden">
        <div class="flex h-auto w-full flex-col px-[clamp(16px,2.4vw,24px)] pb-[clamp(16px,1.6vw,24px)] pt-[clamp(92px,8vw,120px)] sm:px-0 sm:pb-0">
                <div class=" h-auto flex flex-col justify-center">
                    <div class="relative flex h-auto justify-center mb-[clamp(10px,3.1vw,32px)]">
                        <div class="relative z-10 flex w-full flex-col items-center pt-[clamp(18px,3.9vw,40px)] text-[clamp(38px,10.75vw,110px)] leading-[0.9]">
                            
                            <div class="hero-line-1 mb-[clamp(4px,0.8vw,8px)] flex items-center">
                                <span class="font-glancyrThin italic uppercase leading-[0.8]">HELPING</span>
                                <img src={test2.src} alt="" class="ml-[clamp(10px,3.1vw,32px)] h-[clamp(34px,12.7vw,130px)] w-[clamp(112px,34.2vw,350px)] object-contain pb-[clamp(6px,2vw,20px)]" />
                            </div>

                            <div class="hero-line-1 mb-[clamp(0px,0.8vw,8px)] mr-[clamp(-51px,-5vw,-10px)] flex items-center">
                                <span class="mr-[clamp(10px,3.1vw,32px)] font-glancyrThin italic uppercase">YOU</span>
                                <span class="font-glancyrRegular uppercase tracking-tight">CR<span class="font-glancyrThin italic">E</span>ATE A</span>
                            </div>

                            <div class="hero-line-1 relative flex w-full items-end justify-center gap-[clamp(6px,1.6vw,16px)]">
                                <span class="font-glancyrRegular uppercase tracking-tight z-20">DIGITAL</span>
                                
                                <span class="font-baileyRegular absolute z-30 text-[#b3e823] text-[clamp(46px,16.6vw,170px)] leading-[106%] box-shadow2"
                                      style="
                                        left: 50%;
                                        top: 50%;
                                        transform: translate(-57%, -65%) rotate(-11deg);
                                      ">
                                    Mosaic
                                </span>

                                <div class="relative z-20 ml-[clamp(4px,0.8vw,8px)] mb-[clamp(8px,2.3vw,24px)] flex translate-x-[clamp(18px,4.7vw,48px)] translate-y-[clamp(12px,2vw,20px)] flex-col items-end gap-0 font-glancyrRegular text-[clamp(12px,2.35vw,24px)] leading-none">
                                    <span class="leading-none m-0 p-0 block">that</span>
                                    <span class="leading-none m-0 p-0 block">set's you,</span>
                                </div>

                                <div data-cursor="pointer2" class="z-10 ml-[clamp(4px,0.8vw,8px)] flex translate-y-[clamp(10px,2.35vw,24px)] justify-center p-0">
                                    <button class="btn h-[clamp(58px,10.75vw,110px)] w-[clamp(136px,41vw,420px)] overflow-hidden border-none p-0 text-[clamp(34px,9.8vw,100px)] leading-[106%]">
                                        <div class="btn__bg">
                                            <span class="btn__bg__layer btn__bg__layer-first"></span>
                                            <span class="btn__bg__layer btn__bg__layer-second"></span>
                                            <span class="btn__bg__layer btn__bg__layer-third"></span>
                                        </div>
                                        <span class="btn__text-out text-white font-glancyrRegular tracking-tight box-shadow2">APART</span>
                                        <span class="btn__text-in text-white font-glancyrRegular tracking-tight box-shadow2">APART</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
        </div>
    
    
        <div class="absolute bottom-0 z-10 w-full">
            <div class="flex items-center justify-between px-[clamp(20px,4.7vw,48px)] py-[clamp(16px,2.35vw,24px)] text-[clamp(11px,1.95vw,20px)]">
                <div class="flex items-center gap-[clamp(8px,4.7vw,48px)]">
                    <span class=" font-glancyrThin" > TESTIMONIALS</span> 
                    <div class="flex items-center">
                        <img src={arrow.src} class="size-[clamp(16px,2.35vw,24px)]" alt=""/>
                        <span class=" font-glancyrRegular"> SCROLL </span> 
                    </div>
                </div>
                <div class="flex h-[clamp(58px,9.8vw,100px)] items-center">
                    <img src={test1.src} alt="" class="h-[clamp(42px,6vw,61px)] w-[clamp(42px,6vw,61px)]" />
                </div>
            </div>
            <div class="relative z-10 h-auto px-[clamp(20px,4.7vw,48px)]">
                <div class=" bg-border-white h-[1px]">
                </div>
            </div>
        </div>

    </div> 

    <UserReviews />

    <VideoTestimonials />
      <WorkPrivacyPolicy />
      <Footer indexPage={true} />
    
</Layout>
